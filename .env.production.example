# Production environment — copy to .env and fill in real values
# NEVER commit .env to git. Rotate secrets immediately if exposed.

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=tracker
DB_USER=tracker_user
DB_PASSWORD=CHANGE_ME_strong_random_password_here

# ── Auth — generate with: openssl rand -hex 32 ───────────────────────────────
JWT_SECRET=CHANGE_ME_min_32_chars_random_secret
JWT_REFRESH_SECRET=CHANGE_ME_different_min_32_chars_secret
JWT_EXPIRES_IN=15m

# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://tracker.yourdomain.com
BACKEND_PORT=3001
FRONTEND_PORT=80

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── File storage ──────────────────────────────────────────────────────────────
# Local disk (default):
STORAGE_PROVIDER=local

# S3 (recommended for production):
# STORAGE_PROVIDER=s3
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=tracker-uploads-prod

# ── Backups ───────────────────────────────────────────────────────────────────
# BACKUP_RETENTION_DAYS=14
# S3_BACKUP_BUCKET=tracker-backups-prod

# ── Email ─────────────────────────────────────────────────────────────────────
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=
# SMTP_FROM=noreply@yourdomain.com
