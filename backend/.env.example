# ── Database ──────────────────────────────────────────────────────────────────
# For local dev: Docker starts postgres automatically via docker-compose.dev.yml
# Credentials match docker-compose.dev.yml — do NOT change for local dev
DATABASE_URL="postgresql://tracker_user:tracker_pass@localhost:5432/tracker?schema=public"

# ── Auth ──────────────────────────────────────────────────────────────────────
# IMPORTANT: Change both secrets before any production deployment
JWT_SECRET="tracker-dev-secret-do-not-use-in-production"
JWT_REFRESH_SECRET="tracker-refresh-dev-secret-do-not-use-in-production"
JWT_EXPIRES_IN="7d"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:5173"

# ── File uploads (optional — defaults to local disk storage) ─────────────────
# STORAGE_PROVIDER=local
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=

# ── Email (optional — 2FA and notifications) ──────────────────────────────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@tracker.dev
