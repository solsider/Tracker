# Staging environment — copy to .env.staging and fill in real values
# NEVER commit .env.staging to git

# ── Database ──────────────────────────────────────────────────────────────────
STAGING_DB_PASSWORD=staging-strong-password-here

# ── Auth — MUST differ from production ───────────────────────────────────────
STAGING_JWT_SECRET=staging-jwt-secret-min-32-chars-here
STAGING_JWT_REFRESH_SECRET=staging-jwt-refresh-secret-min-32-chars

# ── URLs ──────────────────────────────────────────────────────────────────────
STAGING_FRONTEND_URL=http://staging.tracker.internal
STAGING_API_URL=http://staging-api.tracker.internal

# ── Optional ──────────────────────────────────────────────────────────────────
# STORAGE_PROVIDER=local
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=tracker-staging-uploads
